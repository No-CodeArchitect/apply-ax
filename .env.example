# ─────────────────────────────────────────────────────────────
# apply-ax 환경변수 예시
# 실제 배포 시 이 파일을 복사하여 `.env` 로 만들고 값을 채우세요.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# 세션/토큰 서명용 비밀키 (반드시 길고 임의의 값으로 교체)
# 예: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
SESSION_SECRET=change-me-to-a-long-random-secret-string

# 사이트 기본 URL (비밀번호 재설정 메일의 링크 생성에 사용)
APP_BASE_URL=http://localhost:3000

# ─── SMTP (이메일 발송, nodemailer) ───────────────────────────
# 실제 값은 운영자가 채워 넣으세요. 비어 있으면 메일 발송은 콘솔 로그로 대체됩니다.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="공군 AX 협력센터 <no-reply@example.com>"

# 접수 관련 문의 담당자 안내 (비밀번호 찾기 화면 등에 노출)
SUPPORT_CONTACT=운영 담당자 · support@example.com · 02-000-0000
